{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "App.tsx",
    "index.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "screens/**/*.ts",
    "screens/**/*.tsx",
    "scripts/tests/**/*.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "react-test-renderer.d.ts",
    "nativewind-env.d.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "android",
    "ios",
    "node_modules",
    "supabase/functions"
  ]
}
